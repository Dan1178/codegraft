# codegraft secrets — copy to `.env` and fill in. Never commit your real `.env`.
# Only the `plan` command (and the MCP `generate_plan` tool) needs a key; the
# read-side tools (inspect, impact, symbol, affected-tests, eval*) are free and
# need none.

# Anthropic provider (default). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI provider (optional; only if you run `--provider openai`).
# OPENAI_API_KEY=
